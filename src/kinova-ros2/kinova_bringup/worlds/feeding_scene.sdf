  <!-- ════════════════════════════════════════════════════════════════
       PATIENT MONITOR  — moved to (-0.10, 0.0)  yaw = 0
       Screen faces directly toward patient (+X direction, yaw=0).

       Camera geometry (MODEL frame, yaw=0 so model=world for XY):
         pose:  (0.25, 0, 1.30, 0, 0.409, 0)
         pitch: 0.409 rad = 23.4° down  → aims at patient head
         Camera world pos  : (0.15,  0.0, 1.30)
         Patient head world: (0.75,  0.0, 1.04)
         Distance           : 0.654 m  ✓

       Topics:
         /camera_mouth/color/image_raw
         /camera_mouth/depth/image_rect_raw
       ════════════════════════════════════════════════════════════════ -->
  <model name="patient_monitor">
    <static>true</static>
    <pose>-0.10 0.0 0 0 0 0</pose>
    <link name="monitor_link">

      <!-- Stand base -->
      <collision name="base_col">
        <pose>0 0 0.018 0 0 0</pose>
        <geometry><box><size>0.35 0.35 0.036</size></box></geometry>
      </collision>
      <visual name="stand_base">
        <pose>0 0 0.018 0 0 0</pose>
        <geometry><box><size>0.35 0.35 0.036</size></box></geometry>
        <material><ambient>0.14 0.14 0.16 1</ambient><diffuse>0.14 0.14 0.16 1</diffuse><specular>0.12 0.12 0.12 1</specular></material>
      </visual>

      <!-- Vertical pole -->
      <collision name="pole_col">
        <pose>0 0 0.50 0 0 0</pose>
        <geometry><cylinder><radius>0.022</radius><length>1.00</length></cylinder></geometry>
      </collision>
      <visual name="stand_pole">
        <pose>0 0 0.50 0 0 0</pose>
        <geometry><cylinder><radius>0.022</radius><length>1.00</length></cylinder></geometry>
        <material><ambient>0.20 0.20 0.22 1</ambient><diffuse>0.20 0.20 0.22 1</diffuse><specular>0.18 0.18 0.18 1</specular></material>
      </visual>

      <!-- Horizontal arm toward patient (+X) -->
      <visual name="arm_h">
        <pose>0.115 0 1.010 0 0 0</pose>
        <geometry><box><size>0.230 0.018 0.016</size></box></geometry>
        <material><ambient>0.20 0.20 0.22 1</ambient><diffuse>0.20 0.20 0.22 1</diffuse></material>
      </visual>
      <visual name="vesa_mount">
        <pose>0.240 0 1.010 0 0 0</pose>
        <geometry><box><size>0.028 0.065 0.065</size></box></geometry>
        <material><ambient>0.20 0.20 0.22 1</ambient><diffuse>0.20 0.20 0.22 1</diffuse></material>
      </visual>

      <!-- Monitor housing -->
      <collision name="monitor_col">
        <pose>0.265 0 1.130 0 0 0</pose>
        <geometry><box><size>0.038 0.395 0.280</size></box></geometry>
      </collision>
      <visual name="monitor_housing">
        <pose>0.265 0 1.130 0 0 0</pose>
        <geometry><box><size>0.038 0.395 0.280</size></box></geometry>
        <material><ambient>0.10 0.10 0.12 1</ambient><diffuse>0.10 0.10 0.12 1</diffuse><specular>0.06 0.06 0.06 1</specular></material>
      </visual>

      <!-- Screen face (emissive) -->
      <visual name="screen_face">
        <pose>0.286 0 1.130 0 0 0</pose>
        <geometry><box><size>0.004 0.370 0.255</size></box></geometry>
        <material>
          <ambient>0.05 0.18 0.40 1</ambient>
          <diffuse>0.05 0.18 0.40 1</diffuse>
          <specular>0.85 0.85 0.85 1</specular>
          <emissive>0.03 0.12 0.28 1</emissive>
        </material>
      </visual>

      <!-- Bezels -->
      <visual name="bezel_top">   <pose>0.282 0  1.274 0 0 0</pose><geometry><box><size>0.014 0.398 0.016</size></box></geometry><material><ambient>0.08 0.08 0.10 1</ambient><diffuse>0.08 0.08 0.10 1</diffuse></material></visual>
      <visual name="bezel_bottom"><pose>0.282 0  0.984 0 0 0</pose><geometry><box><size>0.014 0.398 0.016</size></box></geometry><material><ambient>0.08 0.08 0.10 1</ambient><diffuse>0.08 0.08 0.10 1</diffuse></material></visual>
      <visual name="bezel_left">  <pose>0.282  0.196 1.130 0 0 0</pose><geometry><box><size>0.014 0.008 0.260</size></box></geometry><material><ambient>0.08 0.08 0.10 1</ambient><diffuse>0.08 0.08 0.10 1</diffuse></material></visual>
      <visual name="bezel_right"> <pose>0.282 -0.196 1.130 0 0 0</pose><geometry><box><size>0.014 0.008 0.260</size></box></geometry><material><ambient>0.08 0.08 0.10 1</ambient><diffuse>0.08 0.08 0.10 1</diffuse></material></visual>

      <!-- Camera housing on bezel top -->
      <visual name="camera_housing">
        <pose>0.286 0 1.283 0 0 0</pose>
        <geometry><box><size>0.042 0.096 0.020</size></box></geometry>
        <material><ambient>0.06 0.06 0.08 1</ambient><diffuse>0.06 0.06 0.08 1</diffuse></material>
      </visual>
      <visual name="camera_lens">
        <pose>0.309 0 1.283 0 1.5708 0</pose>
        <geometry><cylinder><radius>0.007</radius><length>0.005</length></cylinder></geometry>
        <material><ambient>0.01 0.01 0.01 1</ambient><diffuse>0.01 0.01 0.01 1</diffuse><specular>0.90 0.90 0.90 1</specular></material>
      </visual>
      <visual name="ir_dot_l">
        <pose>0.309  0.025 1.283 0 1.5708 0</pose>
        <geometry><cylinder><radius>0.004</radius><length>0.003</length></cylinder></geometry>
        <material><ambient>0.80 0.02 0.02 1</ambient><diffuse>0.80 0.02 0.02 1</diffuse><emissive>0.40 0.00 0.00 1</emissive></material>
      </visual>
      <visual name="ir_dot_r">
        <pose>0.309 -0.025 1.283 0 1.5708 0</pose>
        <geometry><cylinder><radius>0.004</radius><length>0.003</length></cylinder></geometry>
        <material><ambient>0.80 0.02 0.02 1</ambient><diffuse>0.80 0.02 0.02 1</diffuse><emissive>0.40 0.00 0.00 1</emissive></material>
      </visual>

      <!-- ── RGBD CAMERA  (replaces separate camera + depth_camera) ──────
           type="rgbd_camera" is the ONLY sensor type in Ignition Fortress
           that publishes ALL FOUR topics needed for a point cloud in RViz:

             <topic>/image         → sensor_msgs/Image  (RGB)
             <topic>/depth_image   → sensor_msgs/Image  (32-bit float depth)
             <topic>/points        → sensor_msgs/PointCloud2  ← the missing one
             <topic>/camera_info   → sensor_msgs/CameraInfo  ← needed by rviz

           With the old separate camera+depth_camera approach, Gazebo never
           publishes /points or /camera_info, so RViz has nothing to display.

           Pose in model frame: (0.25, 0, 1.30, 0, 0.409, 0)
             model at (-0.10, 0, 0)  yaw=0
           → camera world pos  : (0.15, 0, 1.30)
           → patient head world : (0.75, 0, 1.04)  distance = 0.654 m  ✓
           ─────────────────────────────────────────────────────────── -->
      <sensor name="camera_mouth_rgbd" type="rgbd_camera">
        <pose>0.25 0 1.30 0 0.409 0</pose>
        <always_on>true</always_on>
        <update_rate>15</update_rate>
        <visualize>false</visualize>
        <camera name="camera_mouth">
          <horizontal_fov>1.047196</horizontal_fov>   <!-- 60 deg FOV -->
          <image>
            <width>640</width>
            <height>480</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.10</near>
            <far>4.0</far>
          </clip>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.004</stddev>
          </noise>
        </camera>
        <!-- Base topic prefix — Gazebo appends /image, /depth_image,
             /points, /camera_info automatically for rgbd_camera.        -->
        <topic>/camera_mouth</topic>
        <gz_frame_id>camera_mouth_optical_frame</gz_frame_id>
      </sensor>

    </link>
  </model>

</world>
</sdf>