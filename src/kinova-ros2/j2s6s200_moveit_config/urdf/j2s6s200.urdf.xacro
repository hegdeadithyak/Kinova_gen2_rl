<?xml version="1.0"?>
<robot name="j2s6s200" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Include the robot macro definition -->
  <xacro:include filename="$(find kinova_description)/urdf/j2s6s200.xacro"/>

  <!-- Fixed world root link -->
  <link name="root"/>

  <!-- Instantiate the arm -->
  <xacro:j2s6s200 base_parent="root" prefix="j2s6s200"/>

</robot>
