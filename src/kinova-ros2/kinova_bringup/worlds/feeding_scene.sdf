        <material><ambient>0.72 0.75 0.80 1</ambient><diffuse>0.72 0.75 0.80 1</diffuse></material>
      </visual>
      <visual name="armrest_left">
        <pose>0 0.255 0.645 0 0 0</pose>
        <geometry><box><size>0.44 0.040 0.028</size></box></geometry>
        <material><ambient>0.52 0.52 0.55 1</ambient><diffuse>0.52 0.52 0.55 1</diffuse></material>
      </visual>
      <visual name="armrest_right">
        <pose>0 -0.255 0.645 0 0 0</pose>
        <geometry><box><size>0.44 0.040 0.028</size></box></geometry>
        <material><ambient>0.52 0.52 0.55 1</ambient><diffuse>0.52 0.52 0.55 1</diffuse></material>
      </visual>
      <visual name="leg_fl"><pose>-0.20  0.20 0.215 0 0 0</pose><geometry><cylinder><radius>0.018</radius><length>0.43</length></cylinder></geometry><material><ambient>0.60 0.62 0.62 1</ambient><diffuse>0.60 0.62 0.62 1</diffuse><specular>0.30 0.30 0.30 1</specular></material></visual>
      <visual name="leg_fr"><pose>-0.20 -0.20 0.215 0 0 0</pose><geometry><cylinder><radius>0.018</radius><length>0.43</length></cylinder></geometry><material><ambient>0.60 0.62 0.62 1</ambient><diffuse>0.60 0.62 0.62 1</diffuse><specular>0.30 0.30 0.30 1</specular></material></visual>
      <visual name="leg_bl"><pose> 0.20  0.20 0.215 0 0 0</pose><geometry><cylinder><radius>0.018</radius><length>0.43</length></cylinder></geometry><material><ambient>0.60 0.62 0.62 1</ambient><diffuse>0.60 0.62 0.62 1</diffuse><specular>0.30 0.30 0.30 1</specular></material></visual>
      <visual name="leg_br"><pose> 0.20 -0.20 0.215 0 0 0</pose><geometry><cylinder><radius>0.018</radius><length>0.43</length></cylinder></geometry><material><ambient>0.60 0.62 0.62 1</ambient><diffuse>0.60 0.62 0.62 1</diffuse><specular>0.30 0.30 0.30 1</specular></material></visual>

    </link>
  </model>

  <!-- ════════════════════════════════════════════════════════════════
       PATIENT  at (0.75, 0)  yaw=π  faces −X toward robot — unchanged
       mouth_target world pos: (0.660, 0, 0.990)  [yaw=0 fix]
       ════════════════════════════════════════════════════════════════ -->
  <model name="patient">
    <static>true</static>
    <pose>0.75 0 0 0 0 0</pose>
    <link name="link">

      <visual name="thigh_left"><pose>-0.12  0.11 0.46 0 1.5708 0</pose><geometry><cylinder><radius>0.052</radius><length>0.32</length></cylinder></geometry><material><ambient>0.25 0.38 0.62 1</ambient><diffuse>0.25 0.38 0.62 1</diffuse></material></visual>
      <visual name="thigh_right"><pose>-0.12 -0.11 0.46 0 1.5708 0</pose><geometry><cylinder><radius>0.052</radius><length>0.32</length></cylinder></geometry><material><ambient>0.25 0.38 0.62 1</ambient><diffuse>0.25 0.38 0.62 1</diffuse></material></visual>
      <visual name="shin_left"><pose>-0.26  0.11 0.25 0 0 0</pose><geometry><cylinder><radius>0.038</radius><length>0.42</length></cylinder></geometry><material><ambient>0.25 0.38 0.62 1</ambient><diffuse>0.25 0.38 0.62 1</diffuse></material></visual>
      <visual name="shin_right"><pose>-0.26 -0.11 0.25 0 0 0</pose><geometry><cylinder><radius>0.038</radius><length>0.42</length></cylinder></geometry><material><ambient>0.25 0.38 0.62 1</ambient><diffuse>0.25 0.38 0.62 1</diffuse></material></visual>

      <visual name="torso">
        <pose>0 0 0.74 0 0 0</pose>
        <geometry><box><size>0.22 0.28 0.40</size></box></geometry>
        <material><ambient>0.25 0.40 0.65 1</ambient><diffuse>0.25 0.40 0.65 1</diffuse></material>
      </visual>
      <visual name="shoulder_l"><pose>0  0.17 0.88 0 0 0</pose><geometry><sphere><radius>0.054</radius></sphere></geometry><material><ambient>0.25 0.40 0.65 1</ambient><diffuse>0.25 0.40 0.65 1</diffuse></material></visual>
      <visual name="shoulder_r"><pose>0 -0.17 0.88 0 0 0</pose><geometry><sphere><radius>0.054</radius></sphere></geometry><material><ambient>0.25 0.40 0.65 1</ambient><diffuse>0.25 0.40 0.65 1</diffuse></material></visual>
      <visual name="arm_left"><pose>0.04  0.26 0.66 0 0 0</pose><geometry><cylinder><radius>0.038</radius><length>0.36</length></cylinder></geometry><material><ambient>0.88 0.72 0.58 1</ambient><diffuse>0.88 0.72 0.58 1</diffuse></material></visual>
      <visual name="arm_right"><pose>0.04 -0.26 0.66 0 0 0</pose><geometry><cylinder><radius>0.038</radius><length>0.36</length></cylinder></geometry><material><ambient>0.88 0.72 0.58 1</ambient><diffuse>0.88 0.72 0.58 1</diffuse></material></visual>

      <visual name="neck">
        <pose>0 0 0.965 0 0 0</pose>
        <geometry><cylinder><radius>0.030</radius><length>0.055</length></cylinder></geometry>
        <material><ambient>0.88 0.72 0.58 1</ambient><diffuse>0.88 0.72 0.58 1</diffuse></material>
      </visual>
      <visual name="head">
        <pose>0 0 1.040 0 0 0</pose>
        <geometry><sphere><radius>0.098</radius></sphere></geometry>
        <material><ambient>0.88 0.72 0.58 1</ambient><diffuse>0.88 0.72 0.58 1</diffuse><specular>0.06 0.04 0.03 1</specular></material>
      </visual>
      <visual name="eye_left"><pose>-0.086  0.032 1.058 0 0 0</pose><geometry><sphere><radius>0.012</radius></sphere></geometry><material><ambient>0.08 0.06 0.05 1</ambient><diffuse>0.08 0.06 0.05 1</diffuse></material></visual>
      <visual name="eye_right"><pose>-0.086 -0.032 1.058 0 0 0</pose><geometry><sphere><radius>0.012</radius></sphere></geometry><material><ambient>0.08 0.06 0.05 1</ambient><diffuse>0.08 0.06 0.05 1</diffuse></material></visual>
      <visual name="nose"><pose>-0.094 0 1.030 0 0 0</pose><geometry><sphere><radius>0.012</radius></sphere></geometry><material><ambient>0.84 0.68 0.54 1</ambient><diffuse>0.84 0.68 0.54 1</diffuse></material></visual>

      <!-- ── MOUTH TARGET (food delivery point) ───────────────────────
           local (-0.09, 0, 0.990) + yaw=π  → world (0.84, 0, 0.99)
           Red glowing sphere = RL goal, visible in RViz
           ─────────────────────────────────────────────────────────── -->
      <visual name="mouth_target">
        <pose>-0.09 0 0.990 0 0 0</pose>
        <geometry><sphere><radius>0.014</radius></sphere></geometry>
        <material>
          <ambient>0.90 0.10 0.08 1</ambient>
