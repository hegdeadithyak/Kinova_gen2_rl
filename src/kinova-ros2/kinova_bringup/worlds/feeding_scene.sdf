<?xml version="1.0" ?>
<!--
  feeding_scene.sdf  (v2 — arm ↔ monitor swapped)
  ─────────────────────────────────────────────────────────────────────
  LAYOUT  (top view, +X right, +Y up)

                     Y
                     ^
  [MONITOR]          |            [PATIENT in chair]
  (-0.10, 0)         +──────────► (0.75, 0)  facing −X
  yaw=0, camera                   mouth at (0.84, 0, 0.99)
  faces patient      |
                     |   [FOOD TABLE]
                     |   (0.55, -0.25)
                     |        ●
                     |   [ARM PEDESTAL]
                     |   (0.40, -0.50)  arm base z=0.85 m
                     +─────────────────────────────────> X

  REACH VERIFICATION  (arm base 0.40, -0.50, 0.85)
  ──────────────────────────────────────────────────
    → patient mouth (0.84, 0, 0.99)   : 0.681 m  ✓
    → food bowl     (0.55, -0.25, 0.83): 0.292 m  ✓
    j2n6s300 max reach: ~0.90 m

  CAMERA  (depth + RGB on monitor top, monitor at (-0.10, 0), yaw=0)
  ─────────────────────────────────────────────────────────────────────
    camera world pos   : (0.15,  0.0, 1.30)
    patient head world : (0.75,  0.0, 1.04)
    camera–head dist   : 0.654 m
    sensor pitch       : 0.409 rad (23.4° down)  in model frame (yaw=0)
    sensor yaw         : 0.0 rad  (model already faces patient)

  ROBOT SPAWN (update in kinova_launch.py)
  ─────────────────────────────────────────
    arguments=['-name', 'j2n6s300', '-topic', 'robot_description',
               '-x', '0.40', '-y', '-0.50', '-z', '0.85']
-->

<sdf version="1.9">
<world name="feeding_scene">

  <!-- ════════════════════ PHYSICS ════════════════════ -->
  <physics name="default_physics" default="true" type="ode">
    <max_step_size>0.005</max_step_size>
    <real_time_factor>1.0</real_time_factor>
    <real_time_update_rate>200</real_time_update_rate>
    <ode>
      <solver><type>quick</type><iters>50</iters><sor>1.3</sor></solver>
      <constraints>
        <cfm>0.0</cfm><erp>0.2</erp>
        <contact_max_correcting_vel>100</contact_max_correcting_vel>
        <contact_surface_layer>0.001</contact_surface_layer>
      </constraints>
    </ode>
  </physics>

  <!-- ════════════════════ PLUGINS ════════════════════ -->
  <plugin filename="gz-sim-physics-system"   name="gz::sim::systems::Physics"/>
  <plugin filename="gz-sim-sensors-system"   name="gz::sim::systems::Sensors">
    <render_engine>ogre2</render_engine>
  </plugin>
  <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
  <plugin filename="gz-sim-user-commands-system"     name="gz::sim::systems::UserCommands"/>

  <!-- ════════════════════ LIGHTING ════════════════════ -->
  <light type="directional" name="ceiling_main">
    <cast_shadows>false</cast_shadows>
    <pose>0.4 0 4.0 0 0 0</pose>
    <diffuse>0.90 0.92 0.92 1</diffuse>
    <specular>0.22 0.22 0.22 1</specular>
    <direction>0.05 0.0 -1.0</direction>
    <intensity>1.10</intensity>
  </light>

  <!-- Fill: patient-side (arm side now -Y) -->
  <light type="point" name="patient_fill">
    <pose>0.80 -0.30 2.2 0 0 0</pose>
    <diffuse>0.55 0.55 0.58 1</diffuse>
    <specular>0.04 0.04 0.04 1</specular>
    <attenuation>
      <range>5</range><constant>0.45</constant>
      <linear>0.04</linear><quadratic>0.002</quadratic>
    </attenuation>
    <cast_shadows>false</cast_shadows>
  </light>

  <!-- Fill: arm + food tray area -->
  <light type="point" name="arm_fill">
    <pose>0.50 -0.60 2.0 0 0 0</pose>
    <diffuse>0.40 0.42 0.42 1</diffuse>
    <specular>0.03 0.03 0.03 1</specular>
    <attenuation>
      <range>4</range><constant>0.55</constant>
      <linear>0.05</linear><quadratic>0.002</quadratic>
    </attenuation>
    <cast_shadows>false</cast_shadows>
  </light>

  <!-- ════════════════════ GROUND ════════════════════ -->
  <model name="ground_plane">
    <static>true</static>
    <link name="link">
      <collision name="collision">
        <geometry><plane><normal>0 0 1</normal><size>20 20</size></plane></geometry>
        <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface>
      </collision>
      <visual name="visual">
        <geometry><plane><normal>0 0 1</normal><size>20 20</size></plane></geometry>
        <material>
          <ambient>0.82 0.82 0.84 1</ambient>
          <diffuse>0.82 0.82 0.84 1</diffuse>
        </material>
      </visual>
    </link>
  </model>

  <!-- ════════════════════════════════════════════════════════════════
       ROBOT PEDESTAL  — moved to (0.40, -0.50)
       Arm base spawned at z = 0.85 m.
       Update launch file: -x 0.40  -y -0.50  -z 0.85
       ════════════════════════════════════════════════════════════════ -->
  <model name="robot_pedestal">
    <static>true</static>
    <pose>0.40 -0.50 0 0 0 0</pose>
    <link name="link">
      <pose>0 0 0.425 0 0 0</pose>
      <collision name="collision">
        <geometry><box><size>0.20 0.20 0.85</size></box></geometry>
      </collision>
      <visual name="visual">
        <geometry><box><size>0.20 0.20 0.85</size></box></geometry>
        <material>
          <ambient>0.15 0.15 0.18 1</ambient>
          <diffuse>0.15 0.15 0.18 1</diffuse>
          <specular>0.12 0.12 0.12 1</specular>
        </material>
      </visual>
    </link>
  </model>

  <!-- ════════════════════════════════════════════════════════════════
       PATIENT CHAIR  at (0.75, 0)  — unchanged
       ════════════════════════════════════════════════════════════════ -->
  <model name="patient_chair">
    <static>true</static>
    <pose>0.75 0 0 0 0 0</pose>
    <link name="link">

      <collision name="seat_col">
        <pose>0 0 0.44 0 0 0</pose>
        <geometry><box><size>0.50 0.50 0.040</size></box></geometry>
      </collision>
      <visual name="seat_frame">
        <pose>0 0 0.44 0 0 0</pose>
        <geometry><box><size>0.50 0.50 0.040</size></box></geometry>
        <material><ambient>0.58 0.58 0.60 1</ambient><diffuse>0.58 0.58 0.60 1</diffuse><specular>0.06 0.06 0.06 1</specular></material>
      </visual>
      <visual name="seat_cushion">
        <pose>0 0 0.472 0 0 0</pose>
        <geometry><box><size>0.46 0.46 0.024</size></box></geometry>
        <material><ambient>0.72 0.75 0.80 1</ambient><diffuse>0.72 0.75 0.80 1</diffuse></material>
      </visual>
      <collision name="backrest_col">
        <pose>0.15 0 0.70 0 0 0</pose>
        <geometry><box><size>0.040 0.46 0.54</size></box></geometry>
      </collision>
      <visual name="backrest_frame">
        <pose>0.15 0 0.70 0 0 0</pose>
        <geometry><box><size>0.040 0.46 0.54</size></box></geometry>
        <material><ambient>0.58 0.58 0.60 1</ambient><diffuse>0.58 0.58 0.60 1</diffuse></material>
      </visual>
      <visual name="backrest_cushion">
        <pose>0.128 0 0.70 0 0 0</pose>
